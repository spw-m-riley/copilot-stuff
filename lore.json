{
  "$schema": "./extensions/lore/schemas/lore.schema.json",
  "enabled": true,
  "latencyTargetsMs": {
    "sessionStartP95": 100,
    "userPromptSubmittedP95": 150
  },
  "latencyReadinessMinSamples": {
    "sessionStart": 20,
    "userPromptSubmitted": 50
  },
  "deferredExtraction": {
    "enabled": true,
    "autoEnqueueOnSessionEnd": true,
    "autoProcessOnSessionStart": true,
    "processCurrentRepositoryOnly": true
  },
  "maintenanceScheduler": {
    "enabled": true,
    "autoRunOnSessionStart": true,
    "maxTasksPerRun": 4,
    "sessionStartBackfill": {
      "enabled": true,
      "includeOtherRepositories": true,
      "refreshExisting": false,
      "batchSize": 25,
      "maxCandidates": 250,
      "maxInspected": 2000,
      "notifyEveryItems": 25
    },
    "tasks": {
      "deferredExtraction": true,
      "validationCorpus": true,
      "replayCorpus": true,
      "backlogReview": true,
      "traceCompaction": true,
      "indexUpkeep": true,
      "doctorSnapshot": true
    }
  },
  "traceRecorder": {
    "maxRecords": 40,
    "maxAgeMs": 1800000,
    "maxRowsPerLookup": 3,
    "maxFilteredRowsPerLookup": 3,
    "maxPromptChars": 160,
    "maxRowChars": 160,
    "maxContextChars": 600,
    "persistDurableSample": true
  },
  "rollout": {
    "ambientPersonaMode": true,
    "autoWriteImprovementGoals": true,
    "directives": true,
    "evolutionLedger": true,
    "generatedArtifactIntegrity": true,
    "hybridRetrieval": true,
    "loreDoctor": true,
    "memoryDomains": true,
    "memoryOperations": true,
    "overlayAutoHydration": true,
    "proposalGeneration": true,
    "refreshableObservations": true,
    "retentionSanitization": true,
    "reviewGate": true,
    "temporalQueryNormalization": true,
    "traceRecorder": true,
    "workstreamOverlays": true
  }
}
