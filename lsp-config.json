{
  "lspServers": {
    "typescript": {
      "command": "npx",
      "args": [
        "-y",
        "-p",
        "typescript",
        "-p",
        "typescript-language-server",
        "typescript-language-server",
        "--stdio"
      ],
      "fileExtensions": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact"
      }
    },
    "gopls": {
      "command": "gopls",
      "args": ["serve"],
      "fileExtensions": {
        ".go": "go"
      }
    },
    "terraformls": {
      "command": "terraform-ls",
      "args": ["serve"],
      "fileExtensions": {
        ".tf": "terraform",
        ".tfvars": "terraform-vars"
      }
    },
    "yamlls": {
      "command": "yaml-language-server",
      "args": ["--stdio"],
      "fileExtensions": {
        ".yml": "yaml",
        ".yaml": "yaml"
      }
    }
  }
}
